# Copy to .env and fill in. .env is gitignored.
# deploy.sh pulls real values from OpenBao and generates .env on the demo host.

# ---- Domain ----
DEMO_DOMAIN=aidefense-demo.uppernyack.com

# ---- Cisco AI Defense ----
AI_DEFENSE_API_KEY=                                  # from OpenBao infra/api/cisco-ai-defense
AI_DEFENSE_REGION=us                                 # us | eu | ap | uae — drives the regional inspect endpoint
AI_DEFENSE_MODE=api                                  # api (default) | gateway (proxy via custom URL)
AI_DEFENSE_GATEWAY_URL=                              # required when MODE=gateway
AI_DEFENSE_BASE_URL=                                 # optional — overrides REGION-derived URL entirely
AI_DEFENSE_MODEL_LABEL=aidefense-demo                # arbitrary string sent as `model` in payload
AI_DEFENSE_DEFAULT_RULES=                            # comma-sep rule names to enable per call; empty = policy default

# ---- NVIDIA NIM (Nemotron) ----
NIM_API_KEY=                                         # from OpenBao infra/api/nvidia-build-netbox-demo
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5   # Super-class, tool-calling clean with "detailed thinking off" prepended to system msg
# Alternates that work on free tier: nvidia/llama-3.3-nemotron-super-49b-v1, mistralai/mistral-nemotron, nvidia/nemotron-3-nano-30b-a3b
# 70B-instruct is NOT accessible on personal free-tier accounts (404)

# ---- NetBox ----
NETBOX_VERSION=v4.4-3.4.0
NETBOX_SECRET_KEY=                                   # 50+ char random — deploy.sh generates if absent
NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@aidefense-demo.local
NETBOX_SUPERUSER_PASSWORD=                           # deploy.sh generates
NETBOX_API_TOKEN=                                    # generated post-bootstrap, stored in OpenBao

# ---- Postgres ----
POSTGRES_DB=netbox
POSTGRES_USER=netbox
POSTGRES_PASSWORD=                                   # deploy.sh generates

# ---- Redis (queue + cache use separate instances per NetBox best practice) ----
REDIS_PASSWORD=                                      # deploy.sh generates
REDIS_CACHE_PASSWORD=                                # deploy.sh generates

# ---- Orchestrator behavior ----
ORCHESTRATOR_LOG_LEVEL=INFO
GATE_INPUT_ENABLED=true
GATE_TOOL_ARGS_ENABLED=true
GATE_OUTPUT_ENABLED=true
